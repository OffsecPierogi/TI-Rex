# Threat Intel Dashboard — Environment Variables
# Copy this file to .env and fill in your values.

# PostgreSQL connection string (required)
# Change the username/password for production deployments
DATABASE_URL="postgresql://tirex:tirex@localhost:5432/tirex"

# Auth secret (required) — generate with: openssl rand -base64 32
# The install script generates this automatically. Must be 32+ characters.
AUTH_SECRET=""

# NVD API key — speeds up CVE ingestion (10x higher rate limit)
# Free at https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=""

# VirusTotal API key — enables hash/IP/domain reputation lookups
# Free tier: 4 requests/minute. Get one at https://www.virustotal.com/
VIRUSTOTAL_API_KEY=""

# Hybrid Analysis API key — enables sandbox detonation results
# Free at https://www.hybrid-analysis.com/
HYBRID_ANALYSIS_API_KEY=""

# AlienVault OTX API key — enables live IOC feed ingestion
# Free at https://otx.alienvault.com/
OTX_API_KEY=""

# AbuseIPDB API key — enables IP reputation checks
# Free at https://www.abuseipdb.com/
ABUSEIPDB_API_KEY=""

# Shodan API key — enables host/port intelligence
# Free at https://www.shodan.io/
SHODAN_API_KEY=""
